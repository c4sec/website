# Contact form email delivery (Resend — https://resend.com)
# Create an API key in the Resend dashboard and add it in Vercel:
#   Project → Settings → Environment Variables
RESEND_API_KEY=

# The "from" address. Until you verify your own domain in Resend you can use
# the shared test sender below. After verifying c4sec.com, use e.g.:
#   C4Sec <noreply@c4sec.com>
CONTACT_FROM="C4Sec Website <onboarding@resend.dev>"
